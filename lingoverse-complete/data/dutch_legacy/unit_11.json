        {
          "type": "teach",
          "nl": "warm",
          "en": "warm/hot",
          "img": "🌡️🔥",
          "phonetic": "varm",
          "example": "Het is warm vandaag.",
          "exampleEn": "It is warm today.",
          "note": "Same as English! 'Heel warm' = very hot. 'Te warm' = too hot.",
          "kind": "word"

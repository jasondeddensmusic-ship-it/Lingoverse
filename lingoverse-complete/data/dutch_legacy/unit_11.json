      "steps": [
        {
          "type": "intro",
          "title": "Hot, Cold & Seasons 🌡️",
          "desc": "Describe temperature and learn the four Dutch seasons.",
          "goals": [
            "Temperature adjectives",
            "The four seasons",
            "Describe seasonal activities"
          ]

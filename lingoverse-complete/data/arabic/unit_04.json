  "lessons": [
    {
      "id": "aru4l1",
      "title": "قهوة وشاي ☕",
      "xp": 25,
      "steps": [
        {
          "type": "intro",
          "title": "Coffee & Tea ☕",
          "desc": "The Arabic coffee and tea ritual — ordering your first drink in a café.",
          "goals": [
            "Coffee & tea vocabulary",
            "Ordering basics",
            "Café culture"
          ]
        },
        {
          "type": "teach",
          "nl": "قهوة",
          "en": "coffee",
          "img": "☕🫘",
          "phonetic": "QAH-wa",
          "example": "قهوة من فضلك",
          "exampleEn": "Coffee please",
          "note": "Arabic coffee (قهوة عربية) is served strong and often with cardamom. The word 'coffee' itself comes from Arabic 'قهوة'!",
          "kind": "word"
        },
        {
          "type": "teach",
          "nl": "شاي",
          "en": "tea",
          "img": "🫖🍵",
          "phonetic": "SHAAY",
          "example": "شاي بالنعناع",
          "exampleEn": "Tea with mint",
          "note": "Mint tea (شاي بالنعناع) is the signature drink across North Africa and the Levant.",
          "kind": "word"
        },
        {
          "type": "teach",
          "nl": "ماء",
          "en": "water",
          "img": "💧🥤",
          "phonetic": "MAA-a",
          "example": "ماء بارد من فضلك",
          "exampleEn": "Cold water please",
          "note": "ماء (water) is one of the most useful words. بارد (baarid) = cold.",
          "kind": "word"
        },
        {
          "type": "teach",
          "nl": "أريد",
          "en": "I want",
          "img": "👉✨",
          "phonetic": "u-REED",
          "example": "أريد قهوة",
          "exampleEn": "I want coffee",
          "note": "أريد is the most direct way to order. Very common and perfectly polite when followed by من فضلك (please).",
          "kind": "word"
        },
        {
          "type": "tip",
          "title": "☕ The Arabic Coffee Ritual",
          "text": "Coffee in the Arab world is MUCH more than a drink:\n\n☕ Arabic coffee (قهوة عربية) is served in small cups and constantly refilled\n🫖 Refusing a cup can be seen as impolite\n🤝 Coffee is the first thing offered to any guest\n💰 The host ALWAYS pays — splitting the bill is rare among friends\n\nTo signal you've had enough, gently shake the cup side to side!"
        },
        {
          "type": "mc",
          "q": "You want to order coffee. You say:",
          "opts": [
            "شاي من فضلك",
            "أريد قهوة",
            "الحساب من فضلك",
            "شكرا"
          ],
          "ans": "أريد قهوة",
          "hint": "أريد = I want"
        },
        {
          "type": "match",
          "mks": [
            "ar_coffee",
            "ar_tea",
            "ar_water",
            "ar_i_want"
          ]
        },
        {
          "type": "tr",
          "mk": "ar_coffee",
          "dir": "comprehend"
        },
        {
          "type": "tr",
          "mk": "ar_i_want",
          "dir": "produce"
        }
      ]
    },
    {
      "id": "aru4l2",
      "title": "فلافل وحمص 🧆",
      "xp": 25,
      "steps": [
        {
          "type": "intro",
          "title": "Street Food 🧆",
          "desc": "Arabic food vocabulary — from hummus to shawarma, plus ordering and paying.",
          "goals": [
            "Food vocabulary",
            "Ordering at a restaurant",
            "Paying the bill"
          ]
        },
        {
          "type": "teach",
          "nl": "خبز",
          "en": "bread",
          "img": "🫓🍞",
          "phonetic": "KHUBZ",
          "example": "خبز عربي",
          "exampleEn": "Arabic bread",
          "note": "Bread (خبز) is eaten with EVERY meal in the Arab world. Arabic flatbread is used to scoop up food — no cutlery needed!",
          "kind": "word"
        },
        {
          "type": "teach",
          "nl": "حمص",
          "en": "hummus",
          "img": "🧆🫘",
          "phonetic": "HUM-mus",
          "example": "حمص مع خبز",
          "exampleEn": "Hummus with bread",
          "note": "Hummus (حمص) literally means 'chickpeas'. It's a staple across the entire Middle East.",
          "kind": "word"
        },
        {
          "type": "teach",
          "nl": "فلافل",
          "en": "falafel",
          "img": "🧆🌿",
          "phonetic": "fa-LAA-fil",
          "example": "فلافل مع سلطة",
          "exampleEn": "Falafel with salad",
          "note": "Falafel is deep-fried chickpea balls — the most famous Arab street food worldwide.",
          "kind": "word"
        },
        {
          "type": "teach",
          "nl": "شاورما",
          "en": "shawarma",
          "img": "🌯🥙",
          "phonetic": "sha-WAR-ma",
          "example": "شاورما دجاج",
          "exampleEn": "Chicken shawarma",
          "note": "Shawarma = meat carved from a rotating spit, wrapped in bread. دجاج (dajaaj) = chicken, لحم (lahm) = meat.",
          "kind": "word"
        },
        {
          "type": "teach",
          "nl": "لذيذ",
          "en": "delicious",
          "img": "😋👨‍🍳",
          "phonetic": "la-ZEEZ",
          "example": "!الأكل لذيذ جدا",
          "exampleEn": "The food is very delicious!",
          "note": "Say لذيذ! after a meal to compliment the cook — Arabs love hearing this.",
          "kind": "word"
        },
        {
          "type": "teach",
          "nl": "الحساب",
          "en": "the bill",
          "img": "💰📋",
          "phonetic": "al-hi-SAAB",
          "example": "الحساب من فضلك",
          "exampleEn": "The bill please",
          "note": "الحساب من فضلك is how you ask for the check. In many Arab countries, the host insists on paying.",
          "kind": "word"
        },
        {
          "type": "tip",
          "title": "🍽️ Arab Food Culture",
          "text": "Food in Arab culture is about SHARING and generosity:\n\n🫓 Bread is shared from a central plate — tear, don't cut\n🤲 Always eat with your RIGHT hand\n🍽️ The host always serves guests first\n💬 Say 'بسم الله' (bismillah) before eating and 'الحمد لله' (alhamdulillah) after\n😋 Compliment the food: 'لذيذ!' (delicious!)\n\nRefusing seconds can take 3-4 polite attempts!"
        },
        {
          "type": "mc",
          "q": "'الحساب من فضلك' means:",
          "opts": [
            "More water please",
            "The bill please",
            "Delicious food!",
            "I want coffee"
          ],
          "ans": "The bill please",
          "hint": "الحساب = the bill, من فضلك = please"
        },
        {
          "type": "match",
          "mks": [
            "ar_bread",
            "ar_hummus",
            "ar_falafel",
            "ar_shawarma"
          ]
        },
        {
          "type": "mc",
          "q": "How do you say 'delicious' in Arabic?",
          "opts": [
            "حمص",
            "شاورما",
            "لذيذ",
            "خبز"
          ],
          "ans": "لذيذ",
          "hint": "la-ZEEZ"
        },
        {
          "type": "tr",
          "mk": "ar_delicious",
          "dir": "comprehend"
        },
        {
          "type": "tr",
          "mk": "ar_the_bill",
          "dir": "produce"
        }
      ]
    }
  ]
}

  "lessons": [
    {
      "id": "aru1l1",
      "title": "السلام عليكم 🕌",
      "xp": 20,
      "steps": [
        {
          "type": "intro",
          "title": "Peace Be Upon You 🕌",
          "desc": "The most important Arabic greeting — a greeting of peace used across the entire Arabic-speaking world.",
          "goals": [
            "The peace greeting",
            "Morning/evening greetings",
            "Reply patterns"
          ]
        },
        {
          "type": "teach",
          "nl": "السلام عليكم",
          "en": "Peace be upon you",
          "img": "🕌☮️",
          "phonetic": "as-sa-LAA-mu a-LAY-kum",
          "example": "السلام عليكم! كيف حالك؟",
          "exampleEn": "Peace be upon you! How are you?",
          "note": "THE universal Arabic greeting. The reply is ALWAYS 'وعليكم السلام' (And upon you peace). This exchange is deeply embedded in Arab culture.",
          "kind": "phrase"
        },
        {
          "type": "teach",
          "nl": "وعليكم السلام",
          "en": "And upon you peace",
          "img": "☮️🤝",
          "phonetic": "wa-a-LAY-kum as-sa-LAAM",
          "example": "وعليكم السلام! أهلا وسهلا!",
          "exampleEn": "And upon you peace! Welcome!",
          "note": "The mandatory reply to السلام عليكم. NOT replying is considered very rude.",
          "kind": "phrase"
        },
        {
          "type": "teach",
          "nl": "مرحبا",
          "en": "Hello",
          "img": "👋😊",
          "phonetic": "MAR-ha-ba",
          "example": "مرحبا! أنا سعيد",
          "exampleEn": "Hello! I am happy.",
          "note": "A casual hello. Works everywhere. Less formal than السلام عليكم.",
          "kind": "word"
        },
        {
          "type": "teach",
          "nl": "صباح الخير",
          "en": "Good morning",
          "img": "🌅☀️",
          "phonetic": "sa-BAAH al-KHAYR",
          "example": "صباح الخير يا أستاذ!",
          "exampleEn": "Good morning, teacher!",
          "note": "Literally 'Morning of goodness'. Reply: 'صباح النور' (Morning of light). Arabic greetings come in call-and-response pairs!",
          "kind": "phrase"
        },
        {
          "type": "tip",
          "title": "☮️ The Greeting Ritual",
          "text": "Arabic greetings are a RITUAL, not just words:\n\nCall: السلام عليكم (Peace be upon you)\nResponse: وعليكم السلام (And upon you peace)\n\nCall: صباح الخير (Morning of goodness)\nResponse: صباح النور (Morning of light)\n\nCall: مساء الخير (Evening of goodness)\nResponse: مساء النور (Evening of light)\n\nArabic speakers notice and appreciate when learners participate in these exchanges!"
        },
        {
          "type": "mc",
          "q": "Someone says 'السلام عليكم'. You reply:",
          "opts": [
            "مرحبا",
            "صباح الخير",
            "وعليكم السلام",
            "شكرا"
          ],
          "ans": "وعليكم السلام",
          "hint": "Mirror the peace greeting back"
        },
        {
          "type": "match",
          "mks": [
            "ar_greet_peace",
            "ar_greet_morning",
            "greet_hello",
            "ar_greet_evening"
          ]
        },
        {
          "type": "mc",
          "q": "The reply to 'صباح الخير' is:",
          "opts": [
            "صباح النور",
            "مساء النور",
            "وعليكم السلام",
            "شكرا"
          ],
          "ans": "صباح النور",
          "hint": "Morning of... light!"
        },
        {
          "type": "tr",
          "mk": "ar_greet_peace",
          "dir": "comprehend"
        },
        {
          "type": "tr",
          "mk": "ar_greet_peace_reply",
          "dir": "comprehend"
        }
      ]
    },
    {
      "id": "aru1l2",
      "title": "أهلا وسهلا 🤝",
      "xp": 20,
      "steps": [
        {
          "type": "intro",
          "title": "Welcome & Goodbyes 🤝",
          "desc": "Welcoming guests and saying goodbye — hospitality is central to Arab culture.",
          "goals": [
            "Welcome phrases",
            "Goodbye variations",
            "Please and thank you"
          ]
        },
        {
          "type": "teach",
          "nl": "أهلا وسهلا",
          "en": "Welcome",
          "img": "🤝🏠",
          "phonetic": "AH-lan wa-SAH-lan",
          "example": "أهلا وسهلا في بيتنا!",
          "exampleEn": "Welcome to our home!",
          "note": "Literally 'family and ease' — you are among family and can be at ease. Arab hospitality is legendary.",
          "kind": "phrase"
        },
        {
          "type": "teach",
          "nl": "شكرا",
          "en": "Thank you",
          "img": "🙏💛",
          "phonetic": "SHUK-ran",
          "example": "شكرا جزيلا!",
          "exampleEn": "Thank you very much!",
          "note": "Add 'جزيلا' (jazeelan = very much) for emphasis. Reply: 'عفوا' (afwan = you're welcome).",
          "kind": "word"
        },
        {
          "type": "teach",
          "nl": "من فضلك",
          "en": "Please",
          "img": "🙏✨",
          "phonetic": "min FAD-lak",
          "example": "ماء من فضلك",
          "exampleEn": "Water please",
          "note": "Literally 'from your grace'. Changes by gender but masculine form works everywhere to start.",
          "kind": "phrase"
        },
        {
          "type": "teach",
          "nl": "مع السلامة",
          "en": "Goodbye",
          "img": "👋☮️",
          "phonetic": "ma-a as-sa-LAA-ma",
          "example": "مع السلامة! إلى اللقاء!",
          "exampleEn": "Goodbye! See you!",
          "note": "Literally 'with peace/safety' — you're wishing them safety on their journey.",
          "kind": "phrase"
        },
        {
          "type": "tip",
          "title": "🏠 Arab Hospitality",
          "text": "Hospitality (ضيافة — diyaafa) is a pillar of Arab culture:\n\n☕ Offering tea or coffee to ANY guest is obligatory\n🏠 'أهلا وسهلا' is said even to strangers\n🍽️ Refusing food is considered impolite\n👋 Goodbyes are long — you might say goodbye 3-4 times!\n\nArabic speakers are usually DELIGHTED when foreigners try Arabic!"
        },
        {
          "type": "mc",
          "q": "'شكرا جزيلا' means:",
          "opts": [
            "You're welcome",
            "Thank you very much",
            "Please",
            "Goodbye"
          ],
          "ans": "Thank you very much",
          "hint": "شكرا = thanks, جزيلا = very much"
        },
        {
          "type": "match",
          "mks": [
            "polite_thanks",
            "ar_please",
            "ar_bye_peace",
            "ar_greet_welcome"
          ]
        },
        {
          "type": "tr",
          "mk": "ar_bye_peace",
          "dir": "comprehend"
        },
        {
          "type": "tr",
          "mk": "polite_thanks",
          "dir": "produce"
        }
      ]
    }
  ]

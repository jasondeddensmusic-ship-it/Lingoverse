      "steps": [
        {
          "type": "intro",
          "title": "Numbers 0-10 🔢",
          "desc": "Numbers are essential for shopping, telling time, giving your phone number, and everyday life. Let's start with the basics!",
          "goals": [
            "Count from 0 to 10 in Dutch",
            "Pronunciation of Dutch numbers",
            "Use numbers in simple sentences"

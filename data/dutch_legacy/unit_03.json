          "phonetic": "ZAY-vun",
          "example": "Er zijn zeven dagen.",
          "exampleEn": "There are seven days.",
          "note": "Related to English 'seven' — both come from the same Germanic root!",
          "kind": "word"
        },
        {
          "type": "teach",
          "nl": "acht",
          "en": "eight",
          "img": "8️⃣",
          "phonetic": "ahgt",
          "example": "De les begint om acht uur.",
          "exampleEn": "The class starts at eight.",
          "note": "The 'ch' is the Dutch throat sound (like a soft gargle). Practice: 'ahh' + friction.",
          "kind": "word"
        },
        {
          "type": "teach",
          "nl": "negen",
